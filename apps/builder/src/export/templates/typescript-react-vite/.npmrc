# Hoist wallet-connector transitive dependencies so Vite's optimizeDeps.include
# can resolve them from the app root (pnpm isolated layout otherwise skips
# pre-bundling and CJS deps like eventemitter3/debug fail at runtime).
# Mirrors openzeppelin-ui/.npmrc — required for exported EVM wallet stacks.
public-hoist-pattern[]=@wagmi/connectors
public-hoist-pattern[]=@walletconnect/*
public-hoist-pattern[]=@metamask/*
public-hoist-pattern[]=@stellar/freighter-api
public-hoist-pattern[]=eventemitter3
public-hoist-pattern[]=debug

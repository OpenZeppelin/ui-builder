{
  "name": "@openzeppelin/ui-builder-app",
  "private": true,
  "version": "0.12.20",
  "type": "module",
  "bin": {
    "export-app": "src/export/cli/export-app.cjs"
  },
  "scripts": {
    "dev": "vite",
    "build": "NODE_OPTIONS='--max-old-space-size=8192' vite build --emptyOutDir",
    "typecheck": "tsc -p tsconfig.typecheck.json --skipLibCheck && tsc -p tsconfig.vite-config.json",
    "lint": "eslint 'src/**/*.{ts,tsx}' --report-unused-disable-directives --max-warnings 0 --config eslint.config.cjs",
    "lint:fix": "eslint 'src/**/*.{ts,tsx}' --fix --config eslint.config.cjs",
    "lint:all-fix": "eslint 'src/**/*.{ts,tsx,js,cjs,mjs}' --fix --config eslint.config.cjs",
    "lint:config-files": "eslint 'vite.config.ts' 'vitest.config.ts' --report-unused-disable-directives --max-warnings 0 --config eslint.config.cjs",
    "lint:config-files:fix": "eslint 'vite.config.ts' 'vitest.config.ts' --fix --config eslint.config.cjs",
    "fix-all": "pnpm format && pnpm lint:all-fix",
    "preview": "vite preview",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" --config ../../.prettierrc.cjs",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\" --config ../../.prettierrc.cjs",
    "ui:add": "npx shadcn-ui@latest add",
    "test": "NODE_OPTIONS='--max-old-space-size=8192' vitest run",
    "test:watch": "NODE_OPTIONS='--max-old-space-size=8192' vitest",
    "test:coverage": "NODE_OPTIONS='--max-old-space-size=8192' vitest run --coverage",
    "test:report": "NODE_OPTIONS='--max-old-space-size=8192' vitest run --reporter=json --outputFile=./test-results/export-tests.json src/export/__tests__/",
    "export-app": "node src/export/cli/export-app.cjs"
  },
  "dependencies": {
    "@creit.tech/stellar-wallets-kit": "^1.9.5",
    "@hookform/resolvers": "^4.1.3",
    "@icons-pack/react-simple-icons": "^12.9.0",
    "@openzeppelin/adapter-evm": "^2.0.0",
    "@openzeppelin/adapter-midnight": "^2.0.0",
    "@openzeppelin/adapter-polkadot": "^2.0.0",
    "@openzeppelin/adapter-solana": "^2.0.0",
    "@openzeppelin/adapter-stellar": "^2.0.0",
    "@openzeppelin/ui-components": "^2.0.0",
    "@openzeppelin/ui-react": "^2.0.1",
    "@openzeppelin/ui-renderer": "^2.0.0",
    "@openzeppelin/ui-storage": "^1.2.1",
    "@openzeppelin/ui-styles": "^1.0.0",
    "@openzeppelin/ui-types": "^2.0.0",
    "@openzeppelin/ui-utils": "^2.0.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@rainbow-me/rainbowkit": "^2.2.10",
    "@solana/web3.js": "^1.98.4",
    "@stellar/stellar-sdk": "^14.6.1",
    "@tanstack/react-query": "^5.96.2",
    "@types/jszip": "^3.4.1",
    "@uiw/react-textarea-code-editor": "^3.1.1",
    "@wagmi/core": "^2.22.1",
    "@web3icons/react": "^4.1.17",
    "buffer": "^6.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fast-equals": "^5.4.0",
    "jszip": "^3.10.1",
    "lodash-es": "^4.18.1",
    "lucide-react": "^0.510.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.72.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "use-deep-compare-effect": "^1.8.1",
    "viem": "^2.47.10",
    "wagmi": "^2.19.5",
    "zod": "^3.25.76",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@midnight-ntwrk/compact-runtime": "0.9.0",
    "@midnight-ntwrk/ledger": "4.0.0",
    "@midnight-ntwrk/midnight-js-contracts": "2.0.2",
    "@midnight-ntwrk/midnight-js-network-id": "2.0.2",
    "@midnight-ntwrk/midnight-js-types": "2.0.2",
    "@midnight-ntwrk/midnight-js-utils": "2.0.2",
    "@midnight-ntwrk/zswap": "4.0.0",
    "@openzeppelin/adapters-vite": "^2.0.0",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/ga-gtag": "^1.2.0",
    "@types/lodash-es": "^4.17.12",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^3.10.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "jsdom": "^26.1.0",
    "prettier": "3.6.2",
    "prettier-plugin-tailwindcss": "0.6.14",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite": "7.3.2",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.6.0",
    "vitest": "^3.2.4"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/OpenZeppelin/ui-builder",
    "directory": "apps/builder"
  }
}

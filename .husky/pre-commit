#!/usr/bin/env bash
set -e

echo "🔍 Running pre-commit checks..."

# Try to use NVM's Node.js if available
if [ -s "$HOME/.nvm/nvm.sh" ]; then
  # Load NVM
  export NVM_DIR="$HOME/.nvm"
  \. "$NVM_DIR/nvm.sh" # This loads nvm
  
  # Use Node.js 22+ (|| true because nvm use failing is non-fatal; version check below is the gate)
  nvm use 22 >/dev/null 2>&1 || true
  
  echo "✅ Using Node.js $(node -v) from NVM"
fi

# Require Node.js 22+ as specified in package.json
node_version=$(node -v | cut -d. -f1 | sed 's/v//')
if [ "$node_version" -lt 22 ]; then
  echo "❌ Error: Node.js version $(node -v) is incompatible. This project requires Node.js 22.13.0+."
  echo "❌ Commit aborted. Please use Node.js 22+ for development."
  exit 1
fi

# Check if there are any staged files
staged_files=$(git diff --cached --name-only --diff-filter=ACMR)
if [ -z "$staged_files" ]; then
  echo "ℹ️ No files staged for commit, skipping checks."
  exit 0
fi

# Fast checks first - auto-fix file permissions (fails fast if issues)
echo "🔧 Checking and fixing file permissions..."
AUTOFIX_FILE_MODES=true pnpm run check-file-modes

# Expensive operations last - formatting and linting
echo "🎨 Running formatting and linting (this may take a moment)..."
pnpm fix-all

# Re-stage files that were originally staged (to include any formatting fixes)
while IFS= read -r file; do
  [ -n "$file" ] && git add "$file"
done <<< "$staged_files" 